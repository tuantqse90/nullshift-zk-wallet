{
  "manifest_version": 3,
  "name": "NullShift Wallet",
  "version": "0.1.0",
  "description": "Privacy-focused EVM wallet with zero-knowledge proofs. Shield funds, transfer privately, swap anonymously.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.svg",
      "32": "assets/icons/icon-32.svg",
      "48": "assets/icons/icon-48.svg",
      "128": "assets/icons/icon-128.svg"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inpage.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "assets/icons/icon-16.svg",
    "32": "assets/icons/icon-32.svg",
    "48": "assets/icons/icon-48.svg",
    "128": "assets/icons/icon-128.svg"
  }
}
