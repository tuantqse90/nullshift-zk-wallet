pragma solidity ^0.8.24;

import "forge-std/Test.sol";
import "../src/interfaces/IVerifier.sol";
import "../src/verifiers/DepositVerifier.sol";

/// @title E2E Test — Real Noir Proof → Solidity UltraPlonk Verification
/// @notice Tests the full ZK pipeline: Noir circuit → witness → Barretenberg proof → on-chain verification
contract E2ETest is Test {
    DepositVerifier public verifier;

    function setUp() public {
        verifier = new DepositVerifier();
    }

    /// @notice Verify a real deposit proof generated by Noir/Barretenberg
    /// @dev Proof generated from deposit circuit with inputs:
    ///      owner_pubkey = 12345, amount = 1000000, salt = 99999
    ///      commitment = pedersen_hash([12345, 1000000, 99999])
    ///               = 0x2d7e7bb7b8e5019d596924609399db611f0800e269cf7d9cb7134a2b0cb2f895
    function test_realDepositProofVerifies() public view {
        bytes memory proof = hex"";

        bytes32[] memory publicInputs = new bytes32[](1);
        publicInputs[0] = bytes32(0x2d7e7bb7b8e5019d596924609399db611f0800e269cf7d9cb7134a2b0cb2f895);

        bool result = verifier.verify(proof, publicInputs);
        assertTrue(result, "Real deposit proof should verify on-chain");
    }

    /// @notice Ensure a tampered proof fails verification
    function test_tamperedProofFails() public {
        // Use the same proof but flip a byte
        bytes memory proof = hex"";

        // Tamper with the proof — flip byte at index 10
        proof[10] = bytes1(uint8(proof[10]) ^ 0xff);

        bytes32[] memory publicInputs = new bytes32[](1);
        publicInputs[0] = bytes32(0x2d7e7bb7b8e5019d596924609399db611f0800e269cf7d9cb7134a2b0cb2f895);

        // Should revert with invalid proof
        vm.expectRevert();
        verifier.verify(proof, publicInputs);
    }

    /// @notice Ensure wrong public input fails verification
    function test_wrongPublicInputFails() public {
        bytes memory proof = hex"";

        // Use wrong commitment
        bytes32[] memory publicInputs = new bytes32[](1);
        publicInputs[0] = bytes32(0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef);

        // Should revert — proof was generated for a different commitment
        vm.expectRevert();
        verifier.verify(proof, publicInputs);
    }
}
