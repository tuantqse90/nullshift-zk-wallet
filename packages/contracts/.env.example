# NullShift Contract Deployment
# Copy to .env and fill in values

# Deployer wallet private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# RPC endpoints
MONAD_RPC_URL=https://rpc.monad.xyz
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Block explorer API keys (for contract verification)
ETHERSCAN_API_KEY=
MONAD_EXPLORER_API_KEY=

# DEX Router addresses (set to 0xdead if no DEX on target chain)
UNISWAP_ROUTER=0x0000000000000000000000000000000000000000
